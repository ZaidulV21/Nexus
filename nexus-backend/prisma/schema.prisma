// nexus-backend/prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── ENUMS ────────────────────────────────────────────────────

enum Role {
  SUPER_ADMIN
  ADMIN
  CLIENT
}

enum ProjectStatus {
  NEW_ENQUIRY
  CONTACTED
  SITE_VISITED
  QUOTE_SENT
  CONFIRMED
  ADVANCE_PAID
  IN_PROGRESS
  QUALITY_CHECK
  FINAL_INVOICE
  COMPLETED
  CLOSED
}

enum MilestoneStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  DELAYED
}

enum ServiceStatus {
  PENDING
  ASSIGNED
  IN_PROGRESS
  DONE
}

enum QuoteStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
  EXPIRED
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  OVERDUE
}

enum EnquiryStatus {
  NEW
  CONTACTED
  SITE_VISITED
  QUOTE_SENT
  CONFIRMED
  ADVANCE_PAID
  IN_PROGRESS
  QUALITY_CHECK
  FINAL_INVOICE
  COMPLETED
  CLOSED
}

enum DocumentType {
  SITE_PHOTO
  FLOOR_PLAN
  CONTRACT
  INVOICE_DOC
  REPORT
  OTHER
}

// ─── MODELS ───────────────────────────────────────────────────

model User {
  id            String    @id @default(uuid())
  name          String
  email         String    @unique
  phone         String?
  passwordHash  String
  role          Role      @default(CLIENT)
  companyName   String?
  isVerified    Boolean   @default(false)
  avatarUrl     String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  clientProjects    Project[]  @relation("ClientProjects")
  sentMessages      Message[]
  uploadedDocs      Document[]
  assignedEnquiries Enquiry[]
}

model Service {
  id          String   @id @default(uuid())
  name        String   @unique
  description String
  icon        String?
  category    String   @default("General")
  isActive    Boolean  @default(true)
  basePrice   Float?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())

  projectServices ProjectService[]
}

model Project {
  id              String        @id @default(uuid())
  clientId        String
  title           String
  status          ProjectStatus @default(NEW_ENQUIRY)
  location        String?
  startDate       DateTime?
  expectedEndDate DateTime?
  actualEndDate   DateTime?
  totalValue      Float?
  notes           String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  client     User             @relation("ClientProjects",  fields: [clientId],   references: [id])
  services   ProjectService[]
  milestones Milestone[]
  quotes     Quote[]
  invoices   Invoice[]
  documents  Document[]
  messages   Message[]
}

model ProjectService {
  id           String        @id @default(uuid())
  projectId    String
  serviceId    String
  vendorName   String?
  vendorPhone  String?
  status       ServiceStatus @default(PENDING)
  serviceValue Float?
  notes        String?
  createdAt    DateTime      @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  service Service @relation(fields: [serviceId], references: [id])
}

model Milestone {
  id          String          @id @default(uuid())
  projectId   String
  title       String
  description String?
  dueDate     DateTime?
  completedAt DateTime?
  status      MilestoneStatus @default(PENDING)
  sortOrder   Int             @default(0)
  createdAt   DateTime        @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model Quote {
  id              String      @id @default(uuid())
  projectId       String
  quoteNumber     String      @unique
  items           Json
  subtotal        Float
  taxPercent      Float       @default(18)
  taxAmount       Float
  totalAmount     Float
  validUntil      DateTime?
  status          QuoteStatus @default(DRAFT)
  pdfUrl          String?
  notes           String?
  rejectionReason String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model Invoice {
  id             String        @id @default(uuid())
  projectId      String
  invoiceNumber  String        @unique
  items          Json?
  amount         Float
  taxPercent     Float         @default(18)
  taxAmount      Float         @default(0)
  dueDate        DateTime?
  paidAt         DateTime?
  status         InvoiceStatus @default(DRAFT)
  pdfUrl         String?
  paymentMethod  String?
  transactionRef String?
  notes          String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model Document {
  id         String       @id @default(uuid())
  projectId  String
  uploadedBy String
  name       String
  type       DocumentType @default(OTHER)
  fileUrl    String
  fileSize   Int?
  createdAt  DateTime     @default(now())

  project  Project @relation(fields: [projectId],  references: [id], onDelete: Cascade)
  uploader User    @relation(fields: [uploadedBy], references: [id])
}

model Message {
  id        String   @id @default(uuid())
  projectId String
  senderId  String
  content   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  sender  User    @relation(fields: [senderId],  references: [id])
}

model Enquiry {
  id                String        @id @default(uuid())
  name              String
  phone             String
  email             String
  company           String?
  city              String?
  hearAboutUs       String?
  callbackTime      String?
  servicesRequested String[]
  message           String?
  budget            String?
  serviceDetails    Json?
  status            EnquiryStatus @default(NEW)
  assignedTo        String?
  convertedProject  String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  assignee User? @relation(fields: [assignedTo], references: [id])
}
